<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:textSize="50dp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="50dp"
        android:layout_gravity="center"
        />


    <EditText
        android:id="@+id/nama_profil"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:layout_gravity="center"
        android:inputType="text"
        android:background="@drawable/bg_input_field" />

    <EditText
        android:id="@+id/pw_profil"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:layout_gravity="center"
        android:inputType="textPassword"
        android:background="@drawable/bg_input_field"/>

    <EditText
        android:id="@+id/email_profil"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:layout_gravity="center"
        android:inputType="textEmailAddress"
        android:background="@drawable/bg_input_field"/>

    <TextView
        android:id="@+id/teks_edit_profil"
        android:layout_width="90dp"
        android:layout_height="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="250dp"
        android:textSize="15dp"
        android:textStyle="bold"
        android:textColor="#0077B6"
        android:text="EDIT PROFIL"
        />

    <ImageView
        android:id="@+id/navigasi_riwayat"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="215dp"
        app:srcCompat="@drawable/logo_riwayat" />

    <ImageView
        android:id="@+id/navigasi_dashboard"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="178dp"
        android:layout_marginTop="-65dp"
        app:srcCompat="@drawable/logo_home" />

    <ImageView
        android:id="@+id/navigasi_profil"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="305dp"
        android:layout_marginTop="-50dp"
        app:srcCompat="@drawable/logo_profil" />
</LinearLayout>